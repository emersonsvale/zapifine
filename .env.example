# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://api.zapifine.com
SUPABASE_KEY=sb_publishable_xxx

# Gateway secret pra passar policies origin_gate_*.
# Em prod, CF Worker injeta; em dev precisa estar aqui.
SUPABASE_GW_SECRET=

# Service role key (server-only). Necessária em /server/api/team/invite.post.ts
# NUNCA exponha no client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Meta WhatsApp Embedded Signup ───────────────────────────
META_APP_ID=
META_CONFIG_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v20.0

# ─── Server runtime ──────────────────────────────────────────
# Porta onde o Nitro sobe (Coolify mapeia automaticamente)
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
